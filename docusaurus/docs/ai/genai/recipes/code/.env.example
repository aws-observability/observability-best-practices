# AWS Credentials (use your active session)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_SESSION_TOKEN=your-session-token
AWS_DEFAULT_REGION=us-east-1

# Amazon Managed Prometheus (populated by Terraform in Phase 1)
AMP_REMOTE_WRITE_URL=https://aps-workspaces.us-east-1.amazonaws.com/workspaces/ws-xxxxx/api/v1/remote_write
AMP_ENDPOINT=https://aps-workspaces.us-east-1.amazonaws.com/workspaces/ws-xxxxx/

# Azure OpenAI (optional - leave as placeholder for AWS-only demo)
AZURE_OPENAI_ENDPOINT=https://placeholder.openai.azure.com
AZURE_OPENAI_API_KEY=placeholder

# LiteLLM Gateway
LITELLM_API_KEY=demo-master-key
