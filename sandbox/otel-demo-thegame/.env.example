# AWS region for CloudWatch
AWS_REGION=eu-west-1

# CloudWatch log group for OTel demo logs
CW_LOG_GROUP=/otel/demo

# PromQL metric names for spanmetrics (defaults match the OTel Collector
# spanmetrics connector output as seen in CloudWatch).
# "traces.span.metrics.calls" = span count counter (Sum),
# "traces.span.metrics.duration" = span duration histogram.
PROMQL_CALLS_METRIC=traces.span.metrics.calls
PROMQL_DURATION_METRIC=traces.span.metrics.duration

# PromQL label for service name.
# CloudWatch OTLP uses @resource. prefix for OTel resource attributes.
PROMQL_SVC_LABEL=@resource.service.name

# LLM Judge configuration
# Provider: "bedrock" (default), "anthropic", or "openai"
LLM_PROVIDER=bedrock

# Model ID (Bedrock model ID, Anthropic model name, or OpenAI model name)
LLM_MODEL_ID=amazon.nova-pro-v1:0

# API key (required for anthropic and openai providers; not needed for bedrock)
LLM_API_KEY=

# OpenAI-compatible endpoint URL (only used when LLM_PROVIDER=openai)
LLM_ENDPOINT=
